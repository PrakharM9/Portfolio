{
  "version": 2,
  "builds": [
    {
      "src": "portfolio_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "buildCommand": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "portfolio_project/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "portfolio_project.settings"
  },
  "buildCommand": "python manage.py collectstatic --noinput"
}