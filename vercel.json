{
  "version": 2,
  "builds": [
    {
      "src": "portfolio_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "portfolio_project/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "portfolio_project.settings",
    "DJANGO_DEBUG": "False"
  },
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput"
}